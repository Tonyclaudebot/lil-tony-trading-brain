# iMessage recipient — phone number or Apple ID email
ALERT_RECIPIENT=+15555555555

# Comma-separated tickers to scan
WATCHLIST=SPY,QQQ,AAPL,TSLA,NVDA,MSFT,AMZN,META

# How often to scan, in seconds
SCAN_INTERVAL_SECONDS=60

# Options filters
MIN_OPTION_VOLUME=500
MIN_VOLUME_TO_OI_RATIO=2.0
MAX_DTE=45
MIN_DTE=1

# Earnings intelligence
EARNINGS_LOOKBACK=8

# Macro calendar (Forex Factory) — days to look ahead for high-impact events
MACRO_WARNING_DAYS=14
MACRO_REFRESH_SECONDS=3600

# Financial Juice breaking news feed
# Get your feed URL from financialjuice.com and paste it here
# Leave blank to disable Financial Juice integration
FINANCIAL_JUICE_FEED_URL=

# Logging
LOG_LEVEL=INFO
