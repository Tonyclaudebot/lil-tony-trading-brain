    <key>Hour</key>
    <integer>18</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/tonybot/Lil-Tony-Trading-Brain/logs/phase1.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/tonybot/Lil-Tony-Trading-Brain/logs/phase1.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>TZ</key>
    <string>America/Chicago</string>
  </dict>

  <key>RunAtLoad</key>
  <false/>

</dict>
</plist>
